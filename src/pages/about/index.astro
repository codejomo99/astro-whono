---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import '../../styles/about.css';
import { getThemeSettings, type SiteSocialIconKey } from '../../lib/theme-settings';
const { settings } = getThemeSettings();
const resolvedSocialItems = settings.site.socialLinks.resolvedSocialItems.filter((item) => item.visible);
const aboutTitle = settings.page.about.title || '소개';
const aboutSubtitle = settings.page.about.subtitle;

type SocialActionItem = {
  key: string;
  href: string;
  label: string;
  title: string;
  icon: SiteSocialIconKey;
};

type ContactItem = {
  key: string;
  href: string;
  icon: SiteSocialIconKey;
  text: string;
};

const formatExternalLabel = (href: string): string => {
  try {
    const parsed = new URL(href);
    const path = parsed.pathname.replace(/^\/+|\/+$/g, '');
    return path || parsed.hostname;
  } catch {
    return href;
  }
};

const socialItems: SocialActionItem[] = [
  ...resolvedSocialItems.map((item) => ({
    key: item.id,
    href: item.href,
    label: item.label,
    title: item.label,
    icon: item.iconKey
  }))
];

const contactItems: ContactItem[] = [
  ...resolvedSocialItems.map((item) => ({
    key: item.id,
    href: item.href,
    icon: item.iconKey,
    text: item.id === 'email' ? item.href.replace(/^mailto:/i, '') : formatExternalLabel(item.href)
  }))
];
---

<BaseLayout title={aboutTitle} bodyClass="about-page">
  <div class="page-header page-header--about">
    <div class="page-heading">
      <h1 class="page-title">{aboutTitle}</h1>
      {aboutSubtitle ? <span class="page-subtitle">{aboutSubtitle}</span> : null}
    </div>
    {
      socialItems.length ? (
        <div class="page-actions">
          {socialItems.map((item) => (
            <a class="icon-link" href={item.href} aria-label={item.title} title={item.title}>
              <Icon name={item.icon} class="icon" />
            </a>
          ))}
        </div>
      ) : null
    }
  </div>
  <p class="about-intro-line">
    Whono는 Astro 기반의 미니멀 2단 글쓰기 테마입니다: 깔끔하고, 빠르며, 읽기에 최적화되어 있습니다.<br />
    콘텐츠는 Markdown으로 작성하며, 다크 모드, 코드 하이라이트, RSS, 몰입 읽기 모드를 지원합니다. 개인 글쓰기와 가벼운 콘텐츠 발행의 출발점으로 적합합니다.<br />
    테마는 오픈소스로 유지되고 있으며, 개선 제안이 있거나 함께 발전시키고 싶다면 <a href="https://github.com/cxro/astro-whono/issues">Issue</a>를 생성하여 소통해 주세요.
  </p>
  <h2 class="section-title about-section-title">섹션 안내</h2>
  <div class="site-guide">
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">수필</h3>
        <span class="site-guide-link">/essay/</span>
      </div>
      <p class="site-guide-desc">글 목록 (아카이브에 포함되지 않은 콘텐츠 포함).</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">조각글</h3>
        <span class="site-guide-link">/bits/</span>
      </div>
      <p class="site-guide-desc">짧은 콘텐츠 피드, 단편적인 생각 (다중 이미지 지원).</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">메모</h3>
        <span class="site-guide-link">/memo/</span>
      </div>
      <p class="site-guide-desc">간직할 만한 순간과 추억을 정리합니다.</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">아카이브</h3>
        <span class="site-guide-link">/archive/</span>
      </div>
      <p class="site-guide-desc">연도별로 그룹화된 아카이브 목록.</p>
    </article>
  </div>

  <h2 class="section-title about-section-title">기술 스택</h2>
  <div class="tech-stack">
    <section class="tech-group">
      <div class="tech-group-title">빌드 및 렌더링</div>
      <ul class="tech-list">
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">Astro / Vite</span>
          </div>
          <div class="tech-item-desc">콘텐츠 사이트 및 빌드</div>
        </li>
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">CSS / 타이포그래피</span>
          </div>
          <div class="tech-item-desc">타이포그래피 및 읽기 경험</div>
        </li>
      </ul>
    </section>
    <section class="tech-group">
      <div class="tech-group-title">언어 및 도구</div>
      <ul class="tech-list">
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">TypeScript</span>
          </div>
          <div class="tech-item-desc">타입 안전성 및 스크립트 지원</div>
        </li>
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">Markdown</span>
          </div>
          <div class="tech-item-desc">콘텐츠 작성 및 배포 프로세스</div>
        </li>
      </ul>
    </section>
    
  </div>

  <h2 class="section-title about-section-title">자주 묻는 질문</h2>
  <section class="qa-list" aria-label="자주 묻는 질문">
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>배포 후 SITE_URL is not set 경고가 나타나는 이유는?</summary>
      <p class="qa-answer">프로덕션 도메인이 설정되지 않았기 때문입니다. 미설정 시 플레이스홀더 도메인을 사용하여 <code>canonical</code>/<code>og:url</code>/<code>sitemap</code>/<code>robots</code>가 불완전해집니다. 배포 플랫폼의 환경 변수에 <code>SITE_URL=https://your-domain</code>을 추가한 후 다시 빌드하면 해결됩니다.</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>일부 글이 아카이브에 나타나지 않는 이유는?</summary>
      <p class="qa-answer">아카이브는 <code>archive: false</code>인 글을 필터링합니다. 해당 글은 여전히 "게시되어 접근 가능"하지만, 아카이브 목록과 아카이브 RSS에 표시되지 않습니다 (목록에 포함시키고 싶지 않은 일부 콘텐츠용).</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>/essay/에서 글을 클릭하면 /archive/.../로 이동하는 이유는?</summary>
      <p class="qa-answer">프로젝트는 글 상세 페이지를 <code>/archive/{'{'}slug{'}'}/</code>로 통합하며, <code>/essay/</code>는 주로 글 목록 진입점 역할을 합니다. 이렇게 하면 중복 상세 경로를 피하고 장기적인 유지보수가 용이해집니다.</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>문제 제보나 개선 참여 방법은?</summary>
      <p class="qa-answer">저장소에서 직접 <a href="https://github.com/cxro/astro-whono/issues">Issue</a>를 생성하거나, <a href="https://github.com/cxro/astro-whono/pulls">Pull Request</a>를 제출해 주세요.</p>
    </details>
  </section>

  {
    contactItems.length ? (
      <>
        <h2 class="section-title about-section-title">연락처 및 구독</h2>
        <section class="contact-block" aria-label="연락처">
          <p class="contact-note">질문, 제안이 있거나 업데이트를 구독하고 싶다면 아래 방법으로 연락해 주세요.</p>
          <ul class="contact-list">
            {contactItems.map((item) => (
              <li>
                <span class="contact-link-head" aria-hidden="true">
                  <Icon name={item.icon} class="contact-icon" />
                </span>
                <a href={item.href}>{item.text}</a>
              </li>
            ))}
          </ul>
        </section>
      </>
    ) : null
  }

</BaseLayout>
