---
import Icon from './Icon.astro';
import { getThemeSettings } from '../lib/theme-settings';

const { settings } = getThemeSettings();
---
<dialog
  class="bits-draft-dialog"
  id="bits-draft-dialog"
  aria-labelledby="bits-draft-title"
  data-default-author-name={settings.page.bits.defaultAuthor.name ?? ''}
  data-default-author-avatar={settings.page.bits.defaultAuthor.avatar ?? ''}
>
  <form class="bits-draft-form" data-bits-draft-form>
    <div class="bits-draft-head">
      <h2 id="bits-draft-title">
        <span class="bits-draft-title-icon" aria-hidden="true">
          <Icon name="pen" />
        </span>
        한마디
      </h2>
      <button class="bits-draft-close" type="button" data-bits-draft-close aria-label="닫기">×</button>
    </div>

    <div class="bits-draft-field">
      <div class="bits-draft-field-head">
        <label for="bits-draft-content">본문 내용</label>
        <div class="bits-draft-toolbar" data-bits-draft-toolbar role="toolbar" aria-label="서식 도구">
          <button type="button" class="bits-draft-tool" data-action="bold" data-tip="굵게" aria-label="굵게">
            <Icon name="bold" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="italic" data-tip="기울임" aria-label="기울임">
            <Icon name="italic" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="code" data-tip="인라인 코드" aria-label="인라인 코드">
            <Icon name="code" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="quote" data-tip="인용" aria-label="인용">
            <Icon name="quote" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="list" data-tip="목록" aria-label="목록">
            <Icon name="list" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="link" data-tip="링크" aria-label="링크">
            <Icon name="link" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="paragraph" data-tip="문단" aria-label="문단">
            <Icon name="paragraph" />
          </button>
        </div>
      </div>
      <textarea
        id="bits-draft-content"
        name="content"
        rows="6"
        required
        placeholder="무언가를 적어보세요…"
      ></textarea>
    </div>

    <div class="bits-draft-row">
      <div class="bits-draft-field bits-draft-half">
        <label for="bits-draft-tags" class="bits-draft-label">
          <span class="bits-draft-label-icon" aria-hidden="true">#</span>
          태그
        </label>
        <input id="bits-draft-tags" name="tags" type="text" inputmode="text" placeholder="쉼표 또는 공백으로 구분" />
        <div class="bits-draft-help">예: 일상 독서 / life reading</div>
      </div>
      <div class="bits-draft-field bits-draft-half">
        <label for="bits-draft-place" class="bits-draft-label">
          <span class="bits-draft-label-icon" aria-hidden="true">
            <Icon name="map-pin" />
          </span>
          장소 (선택)
        </label>
        <input id="bits-draft-place" name="place" type="text" inputmode="text" placeholder="예: 서울" />
        <div class="bits-draft-help">tags에 loc:&lt;장소&gt; 형태로 생성됩니다</div>
      </div>
    </div>

    <div class="bits-draft-stack">
      <div class="bits-draft-field">
        <div class="bits-draft-field-head bits-draft-image-head">
          <div class="bits-draft-field-title">
            <label>이미지 삽입 (선택)</label>
            <button class="bits-draft-image-add" type="button" data-bits-image-add>+ 추가</button>
          </div>
          <div class="bits-draft-help">이미지 크기를 자동으로 인식합니다</div>
        </div>
        <div class="bits-draft-images" data-bits-images>
          <div class="bits-draft-image-row" data-bits-image-row>
            <div class="bits-draft-image-src-wrap">
              <input
                class="bits-draft-image-src"
                data-bits-image-src
                type="text"
                inputmode="url"
                placeholder="bits/xxx.jpg 또는 https://..."
              />
              <button class="bits-draft-image-clear" type="button" data-bits-image-remove aria-label="이미지 제거">x</button>
            </div>
            <input
              class="bits-draft-image-dim"
              data-bits-image-width
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="너비"
            />
            <input
              class="bits-draft-image-dim"
              data-bits-image-height
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="높이"
            />
          </div>
        </div>
        <template data-bits-image-template>
          <div class="bits-draft-image-row" data-bits-image-row>
            <div class="bits-draft-image-src-wrap">
              <input
                class="bits-draft-image-src"
                data-bits-image-src
                type="text"
                inputmode="url"
                placeholder="bits/xxx.jpg 또는 https://..."
              />
              <button class="bits-draft-image-clear" type="button" data-bits-image-remove aria-label="이미지 제거">x</button>
            </div>
            <input
              class="bits-draft-image-dim"
              data-bits-image-width
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="너비"
            />
            <input
              class="bits-draft-image-dim"
              data-bits-image-height
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="높이"
            />
          </div>
        </template>
      </div>

      <div class="bits-draft-status" data-bits-draft-status role="status" aria-live="polite"></div>
      <div class="bits-draft-link-row">
        <button class="bits-draft-link" type="button" data-bits-manual-open hidden>
          <span class="bits-draft-link-icon" aria-hidden="true">
            <Icon name="eye" />
          </span>
          <span>초안 미리보기</span>
          <span class="bits-draft-link-caret" aria-hidden="true">
            <Icon name="chevron-down" />
          </span>
        </button>
      </div>

      <div class="bits-draft-manual" data-bits-manual hidden>
        <div class="bits-draft-manual-title">초안 내용 (읽기 전용)</div>
        <textarea class="bits-draft-manual-textarea" data-bits-manual-textarea rows="6" readonly></textarea>
        <div class="bits-draft-manual-actions">
          <div class="bits-draft-manual-note" data-bits-manual-note></div>
          <button class="bits-draft-secondary" type="button" data-bits-manual-copy>수동 복사</button>
        </div>
      </div>

      <div class="bits-identity-bar" data-identity-bar>
        <div class="bits-identity-caption">
          <span class="bits-identity-label-icon" aria-hidden="true">
            <Icon name="user-circle" />
          </span>
          <span id="bits-identity-heading">작성자 (선택)</span>
        </div>
        <div class="bits-identity-row">
          <div class="bits-identity-controls">
            <button
              class="bits-identity-pill"
              type="button"
              data-identity-pill
              aria-controls="bits-identity-panel"
              aria-expanded="false"
            >
              <span class="bits-identity-avatar" data-identity-avatar aria-hidden="true"></span>
              <span class="bits-identity-name" data-identity-name></span>
            </button>
          </div>
          <button
            class="bits-identity-new"
            type="button"
            data-identity-new
            aria-controls="bits-identity-panel"
            aria-expanded="false"
          >
            작성자 지정
          </button>
        </div>
      </div>

      <div
        id="bits-identity-panel"
        class="bits-identity-advanced"
        data-identity-panel
        role="group"
        aria-labelledby="bits-identity-heading"
        hidden
      >
        <div class="bits-identity-fields">
          <label class="bits-identity-label">
            <span class="bits-identity-label-title">작성자 이름</span>
            <input type="text" name="authorName" inputmode="text" data-author-name />
          </label>
          <label class="bits-identity-label">
            <span class="bits-identity-label-row">
              <span class="bits-identity-label-title">프로필 이미지 경로 (URL)</span>
              <span class="bits-identity-label-hint">비워두면 기본 프로필 사용, 로딩 실패 시 첫 글자 표시</span>
            </span>
            <input type="text" name="authorAvatar" inputmode="url" data-author-avatar />
          </label>
        </div>
        <div class="bits-identity-meta">
          <p class="bits-identity-note">
            비워두면 현재 작성자를 사용하며, author 필드가 추가되지 않습니다
          </p>
          <button type="button" class="bits-identity-reset" data-author-reset>기본값 복원</button>
        </div>
      </div>
    </div>

    <div class="bits-draft-footer">
      <div class="bits-draft-check">
        <input id="bits-draft-draft" name="draft" type="checkbox" />
        <label for="bits-draft-draft">초안으로 표시</label>
        <span class="bits-draft-check-help">초안: 온라인/미리보기에서 기본적으로 표시되지 않음</span>
      </div>
      <div class="bits-draft-actions">
        <button class="bits-draft-primary" type="button" data-bits-draft-generate>생성 후 복사</button>
        <button class="bits-draft-secondary" type="button" data-bits-draft-download>.md 다운로드</button>
      </div>
    </div>
  </form>
</dialog>
